{
  "manifest_version": 2,
  "name": "Paper Translation Popup",
  "version": "0.1.9",
  "description": "Translate selected paper text with OpenAI from a compact Zotero popup.",
  "author": "lobster",
  "homepage_url": "https://github.com/zhstark/zotero9_gpt_plugin",
  "applications": {
    "zotero": {
      "id": "paper-translation-popup@lobster.local",
      "update_url": "https://example.com/paper-translation-popup/updates.json",
      "strict_min_version": "6.999",
      "strict_max_version": "9.0.*"
    }
  }
}
